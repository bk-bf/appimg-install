#!/usr/bin/env bash
# apkg — install, update, and remove AppImages like a native package
# Usage:
#   apkg -S <file.AppImage> [name]
#   apkg -U <file.AppImage> [name]
#   apkg -R <name>
#
# Examples:
#   apkg -S ~/Downloads/mux-0.21.0-x86_64.AppImage mux
#   apkg -S ~/Downloads/mux-0.21.0-x86_64.AppImage        # name inferred
#   apkg -U ~/Downloads/mux-0.22.0-x86_64.AppImage mux
#   apkg -R mux

set -euo pipefail

APPIMAGE_DIR="$HOME/.local/share/appimages"
BIN_DIR="$HOME/.local/bin"
DESKTOP_DIR="$HOME/.local/share/applications"

usage() {
    cat >&2 <<EOF
Usage:
  apkg -S <file.AppImage> [name]   Install or update an AppImage
  apkg -U <file.AppImage> [name]   Same as -S (install from local file)
  apkg -R <name>                   Remove a previously installed AppImage

Options:
  --overwrite-desktop              Force-regenerate the .desktop entry on install/update

Examples:
  apkg -S ~/Downloads/mux-0.21.0-x86_64.AppImage
  apkg -S ~/Downloads/mux-0.21.0-x86_64.AppImage mux
  apkg -U ~/Downloads/mux-0.22.0-x86_64.AppImage mux
  apkg -R mux
  apkg -S ~/Downloads/mux-0.22.0-x86_64.AppImage mux --overwrite-desktop
EOF
    exit 1
}

# --- parse flags ---
mode=""
overwrite_desktop="${UPDATE_DESKTOP:-0}"  # also honour legacy env var

# First pass: extract mode flag and --overwrite-desktop
args=()
for arg in "$@"; do
    case "$arg" in
        -S|-U)   mode="install" ;;
        -R)      mode="remove" ;;
        --overwrite-desktop) overwrite_desktop=1 ;;
        -h|--help) usage ;;
        *) args+=("$arg") ;;
    esac
done

[[ -z "$mode" ]] && usage

# --- remove mode ---
if [[ "$mode" == "remove" ]]; then
    [[ ${#args[@]} -eq 0 ]] && usage
    name="${args[0]}"
    removed=0

    if [[ -f "$APPIMAGE_DIR/$name.AppImage" ]]; then
        rm -f "$APPIMAGE_DIR/$name.AppImage"
        echo "Removed $APPIMAGE_DIR/$name.AppImage"
        removed=1
    fi
    if [[ -L "$BIN_DIR/$name" ]]; then
        rm -f "$BIN_DIR/$name"
        echo "Removed symlink $BIN_DIR/$name"
        removed=1
    fi
    if [[ -f "$DESKTOP_DIR/$name.desktop" ]]; then
        rm -f "$DESKTOP_DIR/$name.desktop"
        echo "Removed $DESKTOP_DIR/$name.desktop"
        removed=1
    fi

    if [[ $removed -eq 0 ]]; then
        echo "Nothing found for '$name'." >&2
        exit 1
    fi
    exit 0
fi

# --- install / update mode ---
[[ ${#args[@]} -eq 0 ]] && usage

src="${args[0]}"

# Resolve to absolute path
src="$(realpath -- "$src")"

if [[ ! -f "$src" ]]; then
    echo "Error: file not found: $src" >&2
    exit 1
fi

# Derive name: strip path, version strings, and .AppImage extension
if [[ ${#args[@]} -ge 2 ]]; then
    name="${args[1]}"
else
    basename_raw="$(basename "$src")"
    # Remove .AppImage (case-insensitive)
    no_ext="${basename_raw%.[Aa][Pp][Pp][Ii][Mm][Aa][Gg][Ee]}"
    # Strip trailing version-like suffixes: -1.2.3, _1.2.3, -x86_64, -aarch64, etc.
    name="$(echo "$no_ext" | sed -E 's/[-_][0-9]+\.[0-9].*//' | sed -E 's/[-_](x86_64|aarch64|arm64|i386|i686)$//' | tr '[:upper:]' '[:lower:]')"
fi

if [[ -z "$name" ]]; then
    echo "Error: could not derive a name. Pass it explicitly as the second argument." >&2
    exit 1
fi

dest="$APPIMAGE_DIR/$name.AppImage"
link="$BIN_DIR/$name"
desktop="$DESKTOP_DIR/$name.desktop"

# Create dirs
mkdir -p "$APPIMAGE_DIR" "$BIN_DIR" "$DESKTOP_DIR"

# Copy (not move — keep original intact) and make executable
cp -f "$src" "$dest"
chmod +x "$dest"

# Symlink
ln -sf "$dest" "$link"

# Desktop entry (only write if it doesn't exist; use --overwrite-desktop to overwrite)
if [[ ! -f "$desktop" ]] || [[ "$overwrite_desktop" == "1" ]]; then
    display_name="$(echo "$name" | sed 's/\b./\u&/g')"   # Title-case
    cat > "$desktop" <<DEOF
[Desktop Entry]
Name=$display_name
Exec=$dest
Icon=application-x-executable
Type=Application
Categories=Utility;
DEOF
    echo "Created $desktop"
fi

echo "Installed '$name'"
echo "  AppImage : $dest"
echo "  Command  : $link"
echo "  Desktop  : $desktop"
echo ""
echo "Update later with the same command — the symlink and .desktop never need changing."
